{
  "name": "accnad-app-offline",
  "version": "2.5.7",
  "type": "module",
  "description": "Professional Offline Accounting & Inventory System",
  "author": "NADTALLY Solutions",
  "private": true,
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:start": "cross-env NODE_ENV=development electron electron-main.cjs",
    "electron:build": "vite build && electron-builder --dir",
    "code:update": "vite build && create-update.bat"
  },
  "build": {
    "appId": "com.accpro.offline",
    "productName": "ACCPRO Offline",
    "npmRebuild": false,
    "directories": {
      "output": "dist_electron_v2"
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "package.json"
    ],
    "win": {
      "target": [
        "dir"
      ],
      "forceCodeSigning": false
    },
    "asar": true
  },
  "dependencies": {
    "app-builder-bin": "^4.2.0",
    "firebase": "^12.6.0",
    "firebase-tools": "^15.5.1",
    "jspdf": "^3.0.4",
    "jspdf-autotable": "^5.0.7",
    "jspreadsheet-ce": "^4.2.1",
    "jsuites": "^4.9.13",
    "lucide-react": "^0.555.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^2.15.4",
    "rxdb": "^15.39.0",
    "rxjs": "^7.5.0",
    "tailwindcss": "^4.1.18",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/vite": "^4.1.18",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.22",
    "cross-env": "^10.1.0",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "uuid": "^13.0.0",
    "vite": "^7.2.4",
    "vite-plugin-pwa": "^1.1.0"
  }
}